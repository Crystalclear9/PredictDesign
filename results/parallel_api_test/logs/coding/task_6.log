elf.availability = False\n            return True\n        return False\n\n    def release(self):\n        self.availability = True\n\nclass ProjectOrganizer:\n    def __init__(self):\n        self.tasks = {}\n        self.resources = {}\n\n    def add_task(self, task_id, description, assigned_to):\n        if task_id not in self.tasks:\n            self.tasks[task_id] = Task(task_id, description, assigned_to)\n            return True\n        return False\n\n    def update_task_status(self, task_id, new_status):\n        if task_id in self.tasks:\n            self.tasks[task_id].update_status(new_status)\n            return True\n        return False\n\n    def add_resource(self, resource_id, name, availability=True):\n        if resource_id not in self.resources:\n            self.resources[resource_id] = Resource(resource_id, name, availability)\n            return True\n        return False\n\n    def allocate_resource(self, resource_id):\n        if resource_id in self.resources:\n            return self.resources[resource_id].allocate()\n        return False\n\n    def release_resource(self, resource_id):\n        if resource_id in self.resources:\n            self.resources[resource_id].release()\n            return True\n        return False\n\n    def get_project_status(self):\n        status_report = {}\n        for task_id, task in self.tasks.items():\n            status_report[task_id] = {\n                \'description\': task.description,\n                \'assigned_to\': task.assigned_to,\n                \'status\': task.status\n            }\n        return status_report\n\n# Example usage\nif __name__ == "__main__":\n    organizer = ProjectOrganizer()\n    organizer.add_task(1, "Design UI", "Alice")\n    organizer.add_resource(1, "Server 1")\n    organizer.allocate_resource(1)\n    organizer.update_task_status(1, "In Progress")\n    print(organizer.get_project_status())\n```\n\nThis `solution.py` file includes basic classes and methods to manage ta