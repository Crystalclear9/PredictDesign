    """Represents an AI-controlled enemy in the game."""
    def __init__(self, name, behavior):
        """
        Initializes a new AI enemy.
        :param name: str - The name of the AI enemy.
        :param behavior: str - The behavior of the AI enemy.
        """
        self.name = name
        self.behavior = behavior

    def move(self):
        """
        Moves the AI enemy.
        """
        print(f"{self.name} moves according to {self.behavior} behavior.")

class KeyPoint:
    """Represents a key point on the map in the game."""
    def __init__(self, position, name):
        """
        Initializes a new key point.
        :param position: tuple - The position of the key point.
        :param name: str - The name of the key point.
        """
        self.position = position
        self.name = name
        self.owner = None

    def capture(self, player):
        """
        Captures the key point by a player.
        :param player: Player - The player capturing the key point.
        """
        self.owner = player
        print(f"{self.name} captured by {player.name}.")

    def defend(self, player):
        """
        Defends the key point by a player.
        :param player: Player - The player defending the key point.
        """
        if self.owner == player:
            print(f"{self.name} is already defended by {player.name}.")
        else:
            print(f"{self.name} cannot be defended by {player.name} as it is not owned by them.")

class Player:
    """Represents a player in the game."""
    def __init__(self, name, character):
        """
        Initializes a new player.
        :param name: str - The name of the player.
        :param character: Character - The character controlled by the player.
        """
        self.name = name
        self.character = character
        self.position = (0, 0)

