    user.add_transaction(Transaction(1000, 'savings', 'Monthly savings'))
    user.add_transaction(Transaction(200, 'expense', 'Groceries'))
    budget = Budget(user)
    budget.update_budget()
    print(budget.get_financial_status())

if __name__ == "__main__":
    main()
