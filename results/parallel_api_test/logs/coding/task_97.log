# solution.py

class User:
    def __init__(self, name):
        self.name = name
        self.transactions = []

    def add_transaction(self, transaction):
        self.transactions.append(transaction)

    def get_transactions(self):
        return self.transactions

class Transaction:
    def __init__(self, amount, category, description):
        self.amount = amount
        self.category = category
        self.description = description

class Budget:
    def __init__(self, user):
        self.user = user
        self.savings = 0
        self.expenses = 0

    def update_budget(self):
        for transaction in self.user.get_transactions():
            if transaction.category == 'savings':
                self.savings += transaction.amount
            else:
                self.expenses += transaction.amount

    def get_financial_status(self):
        return {
            'savings': self.savings,
            'expenses': self.expenses,
            'balance': self.savings - self.expenses
        }

class FinancialAnalyzer:
    def __init__(self, budget):
        self.budget = budget

    def analyze_expenses(self):
        # Placeholder for expense analysis logic
        pass

    def provide_advice(self):
        # Placeholder for providing financial advice
        pass

def main():
    # Example usage
    user = User("John Doe")
    user.add_transaction(Transaction(1000, 'savings', 'Monthly savings'))
    user.add_transaction(Transaction(200, 'expense', 'Groceries'))
    budget = Budget(user)
    budget.update_budget()
    print(budget.get_financial_status())

if __name__ == "__main__":
    main()
```

