 solution = db.Column(db.Text, nullable=False)\\n    user_id = db.Column(db.Integer, db.ForeignKey(\'user.id\'), nullable=False)\\n    user = db.relationship(\'User\', backref=db.backref(\'exercises\', lazy=True))\\n\\ndef create_tables():\\n    db.create_all()\\n\\n@app.route(\'/\')\\ndef index():\\n    return render_template(\'index.html\')\\n\\n@app.route(\'/submit_exercise\', methods=[\'POST\'])\\ndef submit_exercise():\\n    data = request.json\\n    user = User.query.filter_by(username=data[\'username\']).first()\\n    if not user:\\n        user = User(username=data[\'username\'])\\n        db.session.add(user)\\n    exercise = Exercise(title=data[\'title\'], description=data[\'description\'], solution=data[\'solution\'], user=user)\\n    db.session.add(exercise)\\n    db.session.commit()\\n    return jsonify({\'message\': \'Exercise submitted successfully\'}), 201\\n\\n@socketio.on(\'submit_solution\')\\ndef handle_submit_solution(data):\\n    user = User.query.filter_by(username=data[\'username\']).first()\\n    if not user:\\n        user = User(username=data[\'username\'])\\n        db.session.add(user)\\n    exercise = Exercise(title=data[\'title\'], description=data[\'description\'], solution=data[\'solution\'], user=user)\\n    db.session.add(exercise)\\n    db.session.commit()\\n    emit(\'solution_submitted\', {\'message\': \'Solution submitted successfully\'}, broadcast=True)\\n\\nif __name__ == \'__main__\':\\n    create_tables()\\n    socketio.run(app, debug=True)\\n"\n}\n```\n\nThis code sets up a basic Flask application with a SQLite database to store user information and exercises. It includes routes for submitting exercises and handling real-time feedback using Flask-SocketIO. The `create_tables` function initializes the database tables.\n\nPlease ensure that you have Flask, Flask-SQLAlchemy, and Flask-SocketIO installed in your environment to run this code. You can install these packages using pip:\n\n```bash\npip install flask flask_sqlalchemy flask_socketio\n```\n\nThis should provide a starting point for the `LanguageCollaborator` program. Further development can include additional features such as user authentication, more complex exercise handling, and enhanced peer review capabilities.', 'continue_simulation': True, 'communications': [], 'total_milestones': 0, 'agent_kpis': {}}], 'planning_scores': [-1, -1, -1, -1, -1], 'communication_scores': [-1, -1, -1, -1, -1], 'token_usage': 111920, 'agent_kpis': {}, 'total_milestones': 0}
