# solution.py

# Import necessary libraries
from flask import Flask, request, jsonify
from flask_sqlalchemy import SQLAlchemy
import radon.complexity
import radon.metrics

# Initialize the Flask application and database
app = Flask(__name__)
app.config['SQLALCHEMY_DATABASE_URI'] = 'sqlite:///collaboratecraft.db'
db = SQLAlchemy(app)

# Define database models
class User(db.Model):
    id = db.Column(db.Integer, primary_key=True)
    username = db.Column(db.String(80), unique=True, nullable=False)
    email = db.Column(db.String(120), unique=True, nullable=False)
    projects = db.relationship('Project', backref='author', lazy=True)

class Project(db.Model):
    id = db.Column(db.Integer, primary_key=True)
    title = db.Column(db.String(100), nullable=False)
    description = db.Column(db.Text, nullable=False)
    user_id = db.Column(db.Integer, db.ForeignKey('user.id'), nullable=False)
    collaborators = db.relationship('User', secondary='collaborations', backref=db.backref('collaborating_projects', lazy=True))

class Collaboration(db.Model):
    user_id = db.Column(db.Integer, db.ForeignKey('user.id'), primary_key=True)
    project_id = db.Column(db.Integer, db.ForeignKey('project.id'), primary_key=True)

# Define routes for user profile creation
@app.route('/users', methods=['POST'])
def create_user():
    data = request.get_json()
    new_user = User(username=data['username'], email=data['email'])
    db.session.add(new_user)
    db.session.commit()
    return jsonify({'message': 'User created successfully'}), 201

# Define routes for project sharing
@app.route('/projects', methods=['POST'])
def create_project():
    data = request.get_json()
    new_project = Project(title=data['title'], description=data['description'], user_id=data['user_id'])
    db.session.add(new_project)
    db.session.commit()
    return jsonify({'message': 'Project created successfully'}), 201

# Define routes for collaboration
@app.route('/projects/<int:project_id>/collaborators', methods=['POST'])
def add_collaborator(project_id):
    data = request.get_json()
    project = Project.query.get_or_404(project_id)
    collaborator = User.query.get_or_404(data['user_id'])
    project.collaborators.append(collaborator)
    db.session.commit()
    return jsonify({'message': 'Collaborator added successfully'}), 201

# Define routes for feedback and support
@app.route('/projects/<int:project_id>/feedback', methods=['POST'])
def add_feedback(project_id):
    data = request.get_json()
    feedback = data['feedback']
    # Logic to store feedback
    return jsonify({'message': 'Feedback added successfully'}), 201

# Updated analyze_code method
def analyze_code(code_snippet):
    """
    Analyze a code snippet for efficiency using radon library.
    
    :param code_snippet: String containing the code to be analyzed.
    :return: Efficiency metric based on cyclomatic complexity and maintainability index.
    """
    cc = radon.complexity.cc_visit(code_snippet)
    mi = radon.metrics.mi_visit(code_snippet)
    efficiency_metric = sum(func.complexity for func in cc) + mi
    return efficiency_metric

# Example usage
if __name__ == "__main__":
    # Initialize the database
    db.create_all()

    # Example of adding a user
    user_data = {'username': 'testuser', 'email': 'testuser@example.com'}
    response = create_user(user_data)
    print(response.json)

    # Example of adding a project
    project_data = {'title': 'Test Project', 'description': 'A test project', 'user_id': 1}
    response = create_project(project_data)
    print(response.json)

    # Example of adding a collaborator
    collaborator_data = {'user_id': 1}
    response = add_collaborator(1, collaborator_data)
    print(response.json)

    # Example of adding feedback
    feedback_data = {'feedback': 'Great project!'}
    response = add_feedback(1, feedback_data)
    print(response.json)
```

