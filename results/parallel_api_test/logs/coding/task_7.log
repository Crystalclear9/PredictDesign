ts = []\\n        self.collaborations = []\\n\\n    def add_project(self, project):\\n        self.projects.append(project)\\n\\n    def add_collaboration(self, collaboration):\\n        self.collaborations.append(collaboration)\\n\\nclass Project:\\n    def __init__(self, title, description, owner):\\n        self.title = title\\n        self.description = description\\n        self.owner = owner\\n        self.collaborators = []\\n        self.comments = []\\n\\n    def add_collaborator(self, user):\\n        self.collaborators.append(user)\\n\\n    def add_comment(self, user, comment):\\n        self.comments.append((user, comment))\\n\\nclass CollaborateCraft:\\n    def __init__(self):\\n        self.users = {}\\n        self.projects = {}\\n\\n    def register_user(self, username, bio):\\n        if username not in self.users:\\n            self.users[username] = User(username, bio)\\n            return True\\n        return False\\n\\n    def create_project(self, title, description, owner_username):\\n        if owner_username in self.users:\\n            owner = self.users[owner_username]\\n            project = Project(title, description, owner)\\n            self.projects[title] = project\\n            owner.add_project(project)\\n            return True\\n        return False\\n\\n    def add_collaborator_to_project(self, project_title, collaborator_username):\\n        if project_title in self.projects and collaborator_username in self.users:\\n            project = self.projects[project_title]\\n            collaborator = self.users[collaborator_username]\\n            project.add_collaborator(collaborator)\\n            collaborator.add_collaboration(project)\\n            return True\\n        return False\\n\\n    def add_comment_to_project(self, project_title, commenter_username, comment):\\n        if project_title in self.projects and commenter_username in self.users:\\n            project = self.projects[project_title]\\n            commenter = se