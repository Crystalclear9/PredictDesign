        for u in self.tasks:
            for v in self.tasks[u]:
                in_degree[v] += 1
        queue = [u for u in in_degree if in_degree[u] == 0]
        topo_order = []
        while queue:
            u = queue.pop(0)
            topo_order.append(u)
            for v in self.tasks[u]:
                in_degree[v] -= 1
                if in_degree[v] == 0:
