# solution.py

class MealMaster:
    def __init__(self):
        self.recipes = []
        self.nutritional_info = {}
        self.user_preferences = {}

    def add_recipe(self, recipe_name, ingredients, nutritional_values):
        self.recipes.append({
            'name': recipe_name,
            'ingredients': ingredients,
            'nutritional_values': nutritional_values
        })

    def set_user_preferences(self, dietary_preferences, health_goals, available_ingredients, food_allergies):
        self.user_preferences = {
            'dietary_preferences': dietary_preferences,
            'health_goals': health_goals,
            'available_ingredients': available_ingredients,
            'food_allergies': food_allergies
        }

    def suggest_recipes(self):
        # Implement logic to suggest recipes based on user preferences
        suggested_recipes = []
        for recipe in self.recipes:
            if all(ingredient in self.user_preferences['available_ingredients'] for ingredient in recipe['ingredients']):
                if not any(allergy in recipe['ingredients'] for allergy in self.user_preferences['food_allergies']):
                    suggested_recipes.append(recipe['name'])
        return suggested_recipes

    def get_nutritional_info(self, recipe_name):
        # Implement logic to return nutritional information for a given recipe
        for recipe in self.recipes:
            if recipe['name'] == recipe_name:
                return recipe['nutritional_values']
        return None

# Example usage
if __name__ == "__main__":
    meal_master = MealMaster()
    meal_master.add_recipe("Grilled Chicken Salad", ["chicken", "lettuce", "tomato"], {"calories": 300, "protein": 30, "carbs": 10, "fat": 15})
    meal_master.set_user_preferences(dietary_preferences="vegetarian", health_goals="weight_loss", available_ingredients=["chicken", "lettuce", "tomato"], food_allergies=["shellfish"])
    print("Suggested Recipes:", meal_master.suggest_recipes())
    print("Nutritional Info for Grilled Chicken Salad:", meal_master.get_nutritional_info("Grilled Chicken Salad"))
