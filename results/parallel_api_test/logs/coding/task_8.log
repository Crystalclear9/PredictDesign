    def __init__(self, name, description, deadline, assigned_to=None, progress=0):
        self.name = name
        self.description = description
        self.deadline = deadline
        self.assigned_to = assigned_to
        self.progress = progress

    def assign(self, team_member):
        self.assigned_to = team_member

    def update_progress(self, progress):
        self.progress = progress

# Example of adding task management functionality
class TeamCollaborationManager:
    def __init__(self):
        self.tasks = []

    def create_task(self, name, description, deadline):
        task = Task(name, description, deadline)
        self.tasks.append(task)
        return task

    def assign_task(self, task, team_member):
        task.assign(team_member)

    def update_task_progress(self, task, progress):
        task.update_progress(progress)

# Example usage
