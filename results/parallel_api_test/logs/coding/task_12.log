.current_amount -= transaction.amount\n\n    def get_budget_status(self):\n        return {\n            \'budget_id\': self.budget_id,\n            \'goal_amount\': self.goal_amount,\n            \'current_amount\': self.current_amount,\n            \'remaining_amount\': self.goal_amount - self.current_amount\n        }\n\nclass BudgetSync:\n    def __init__(self):\n        self.users = {}\n        self.budgets = {}\n\n    def add_user(self, user_id, name, email):\n        self.users[user_id] = User(user_id, name, email)\n\n    def create_budget(self, budget_id, user_ids, goal_amount):\n        self.budgets[budget_id] = Budget(budget_id, user_ids, goal_amount)\n\n    def add_transaction_to_budget(self, budget_id, transaction):\n        if budget_id in self.budgets:\n            self.budgets[budget_id].add_transaction(transaction)\n\n    def get_budget_status(self, budget_id):\n        if budget_id in self.budgets:\n            return self.budgets[budget_id].get_budget_status()\n        return None\n\n# Example usage\nif __name__ == "__main__":\n    budget_sync = BudgetSync()\n    budget_sync.add_user(1, "Alice", "alice@example.com")\n    budget_sync.add_user(2, "Bob", "bob@example.com")\n    budget_sync.create_budget(1, [1, 2], 1000)\n    budget_sync.add_transaction_to_budget(1, Transaction(1, 1, 500, "Salary", "income"))\n    budget_sync.add_transaction_to_budget(1, Transaction(2, 2, 200, "Groceries", "expense"))\n    print(budget_sync.get_budget_status(1))\n```\n\nThis `solution.py` provides a basic structure for the BudgetSync application, including classes for `User`, `Transaction`, `Budget`, and `BudgetSync`. It also includes example usage to demonstrate how the application can be used.\n\nThe final output in JSON format is:\n\n```json\n{\n  "solution.py": "# solution.py\\n# BudgetSync Application\\n# This system is designed to facilitate collaborative budgeting among multiple users.\\n\\nclass User:\\n    def __init__(self, user_id, name, email):\\n        se