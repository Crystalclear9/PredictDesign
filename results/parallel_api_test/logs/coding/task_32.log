    task_manager = TaskManager()
    task_manager.add_task("task1")
    task_manager.add_task("task2", ["task1"])
    task_manager.add_task("task3", ["task1"])
    task_manager.add_task("task4", ["task2", "task3"])
    task_manager.add_task("task5", ["task4"])
    task_manager.add_task("task6", ["task5", "task4"])  # Introducing a circular dependency

    print(task_manager.can_execute("task1"))  # Should return True
    print(task_manager.can_execute("task2"))  # Should return True
    print(task_manager.can_execute("task3"))  # Should return True
    print(task_manager.can_execute("task4"))  # Should return True
    print(task_manager.can_execute("task5"))  # Should return True
    print(task_manager.can_execute("task6"))  # Should return False due to circular dependency
