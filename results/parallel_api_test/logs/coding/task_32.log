    print(task_manager.can_execute("task2"))  # Should return True
    print(task_manager.can_execute("task3"))  # Should return True
    print(task_manager.can_execute("task4"))  # Should return True
    print(task_manager.can_execute("task5"))  # Should return True
    print(task_manager.can_execute("task6"))  # Should return False due to circular dependency
