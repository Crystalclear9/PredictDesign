# solution.py

class ChainReactionGame:
    def __init__(self, grid_size):
        self.grid_size = grid_size
        self.grid = self._initialize_grid()
        self.timer = 0
        self.current_level = 1

    def _initialize_grid(self):
        # Initialize the grid with nodes
        return [[0 for _ in range(self.grid_size)] for _ in range(self.grid_size)]

    def activate_node(self, x, y):
        # Activate a node and propagate the chain reaction
        if 0 <= x < self.grid_size and 0 <= y < self.grid_size:
            self.grid[x][y] += 1
            self._propagate_chain_reaction(x, y)

    def _propagate_chain_reaction(self, x, y):
        # Propagate the chain reaction from the activated node
        if self.grid[x][y] >= 4:  # Assuming a node explodes when it reaches 4
            self.grid[x][y] = 0
            for dx, dy in [(-1, 0), (1, 0), (0, -1), (0, 1)]:
                nx, ny = x + dx, y + dy
                if 0 <= nx < self.grid_size and 0 <= ny < self.grid_size:
                    self.activate_node(nx, ny)

    def check_win_condition(self):
        # Check if all nodes are cleared
        return all(all(cell == 0 for cell in row) for row in self.grid)

    def start_timer(self):
        # Start the timer
        self.timer = 0
        # Implement timer logic here

    def save_progress(self):
        # Save the current game state
        # Implement saving logic here

# Example usage
