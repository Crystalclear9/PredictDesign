# solution.py
# Multi-Agent Transport Planner (MATP) System
# This system dynamically coordinates and optimizes multi-modal transportation plans for users.

class DataIntegrator:
    """
    Integrates data from various sources such as traffic conditions, public transportation schedules, and weather forecasts.
    """
    def __init__(self):
        self.data_sources = {}

    def add_data_source(self, source_name, data):
        """
        Adds data from a specific source.
        :param source_name: str - The name of the data source.
        :param data: dict - The data to be added.
        """
        self.data_sources[source_name] = data

    def get_integrated_data(self):
        """
        Retrieves integrated data from all sources.
        :return: dict - The integrated data.
        """
        return self.data_sources

class TransportPlanner:
    """
    Plans transportation routes based on integrated data and user preferences.
    """
    def __init__(self, data_integrator):
        self.data_integrator = data_integrator

    def plan_route(self, user_preferences):
        """
        Plans a route based on user preferences and integrated data.
        :param user_preferences: dict - The user's preferences for the route.
        :return: dict - The planned route.
        """
        integrated_data = self.data_integrator.get_integrated_data()
        # Placeholder for route planning logic
        planned_route = {
            'start': user_preferences.get('start'),
            'end': user_preferences.get('end'),
            'mode': user_preferences.get('mode', 'car'),
            'details': 'Placeholder route details'
        }
        return planned_route

class MATPSystem:
    """
    The main class that integrates data and plans routes.
    """
    def __init__(self):
        self.data_integrator = DataIntegrator()
        self.transport_planner = TransportPlanner(self.data_integrator)

    def add_data(self, source_name, data):
        """
        Adds data to the data integrator.
        :param source_name: str - The name of the data source.
        :param data: dict - The data to be added.
        """
        self.data_integrator.add_data_source(source_name, data)

    def plan_user_route(self, user_preferences):
        """
        Plans a route for a user based on their preferences.
        :param user_preferences: dict - The user's preferences for the route.
        :return: dict - The planned route.
        """
        return self.transport_planner.plan_route(user_preferences)

# Example usage
if __name__ == "__main__":
    # Initialize the MATP system
    matp_system = MATPSystem()

    # Add data from various sources
    matp_system.add_data('traffic', {'condition': 'light'})
    matp_system.add_data('public_transport', {'schedule': 'on_time'})
    matp_system.add_data('weather', {'forecast': 'sunny'})

    # Define user preferences
    user_preferences = {
        'start': 'Home',
        'end': 'Work',
        'mode': 'public_transport'
    }

    # Plan the route
    planned_route = matp_system.plan_user_route(user_preferences)
    print("Planned Route:", planned_route)
```

