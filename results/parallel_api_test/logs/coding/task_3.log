er.\n        :param user_id: str - Unique identifier for the user.\n        :return: dict - User\'s schedule.\n        """\n        return self.schedules.get(user_id, {})\n\n    def get_task_status(self, task_id):\n        """\n        Returns the status of a specific task.\n        :param task_id: str - Unique identifier for the task.\n        :return: str - Status of the task.\n        """\n        return self.tasks.get(task_id, {}).get(\'status\', \'unknown\')\n\n# Example usage\nif __name__ == "__main__":\n    planner = CollaborativeSchedulePlanner()\n    planner.add_user(\'user1\', {\'Monday\': [9, 17], \'Tuesday\': [9, 17]})\n    planner.add_user(\'user2\', {\'Monday\': [10, 18], \'Tuesday\': [10, 18]})\n    planner.add_task(\'task1\', \'Design UI\', 1, [\'user1\', \'user2\'])\n    planner.update_schedule()\n    print(planner.get_user_schedule(\'user1\'))\n    print(planner.get_task_status(\'task1\'))\n```\n\nYou should call the `create_code` action with the above code to overwrite the existing `solution.py` file. Here is the action function call:\n\n```json\n{\n    "type": "action_function_call",\n    "action_name": "create_code",\n    "args": {\n        "file_path": "C:\\\\Users\\\\70454\\\\Desktop\\\\PredictDesign\\\\results\\\\parallel_api_test\\\\runtime_configs\\\\coding\\\\task_3_workspace\\\\solution.py",\n        "code": "# solution.py\\n\\nclass CollaborativeSchedulePlanner:\\n    def __init__(self):\\n        self.users = {}\\n        self.tasks = {}\\n        self.schedules = {}\\n\\n    def add_user(self, user_id, availability):\\n        \\"\\"\\"\\n        Adds a user with their availability.\\n        :param user_id: str - Unique identifier for the user.\\n        :param availability: dict - Dictionary of availability (e.g., {\'Monday\': [9, 17], \'Tuesday\': [9, 17], ...}).\\n        \\"\\"\\"\\n        self.users[user_id] = availability\\n\\n    def add_task(self, task_id, description, priority, required_users=None):\\n        \\"\\"\\"\\n   