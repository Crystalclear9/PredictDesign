        """
        Adds a user with their availability.
        :param user_id: str - Unique identifier for the user.
        :param availability: dict - Dictionary of availability (e.g., {'Monday': [9, 17], 'Tuesday': [9, 17], ...}).
        """
        self.users[user_id] = availability

    def add_task(self, task_id, description, priority, required_users=None):
        """
