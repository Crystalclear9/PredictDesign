# solution.py

class OfficeTaskScheduler:
    """
    The OfficeTaskScheduler class is designed to manage and schedule tasks for multiple team members
    within an office environment. This class provides methods to create, assign, and track tasks,
    set deadlines and priorities, and monitor the progress of each task.
    """

    def __init__(self):
        """
        Initialize the OfficeTaskScheduler with empty data structures for tasks and code analysis.
        """
        self.tasks = {}  # Dictionary to store tasks with their details
        self.code_efficiency = {}  # Dictionary to store code efficiency metrics
        self.task_code_map = {}  # Dictionary to map task IDs to code snippets

    def add_task(self, task_id, description, deadline, priority, dependencies=None):
        """
        Add a new task to the task manager with optional dependencies.

        :param task_id: Unique identifier for the task.
        :param description: Description of the task.
        :param deadline: Deadline for the task (datetime.date).
        :param priority: Priority level of the task (integer).
        :param dependencies: List of task IDs that this task depends on.
        """
        if dependencies is None:
            dependencies = []
        if task_id in self.tasks:
            raise ValueError(f"Task ID {task_id} already exists.")
        self.tasks[task_id] = {
            'description': description,
            'deadline': deadline,
            'priority': priority,
            'dependencies': dependencies,
            'completed': False
        }
        self.task_code_map[task_id] = None  # Initialize with None

    def analyze_code(self, task_id, code_snippet):
        """
        Analyze a code snippet for efficiency and associate it with a task. This is a simplified example
        that counts the number of lines as a proxy for code efficiency. In a real-world scenario, this
        could involve more complex analysis.

        :param task_id: Unique identifier for the task.
        :param code_snippet: String containing the code to be analyzed.
        :return: Efficiency metric (e.g., number of lines).
        """
        if task_id not in self.tasks:
            raise ValueError(f"Task ID {task_id} does not exist.")
        lines = code_snippet.split('\n')
        efficiency_metric = len(lines)
        self.code_efficiency[code_snippet] = efficiency_metric
        self.task_code_map[task_id] = code_snippet  # Map the task ID to the code snippet
        return efficiency_metric

    def estimate_build_time(self):
        """
        Estimate the build time based on the number of tasks and their dependencies, considering the efficiency of the code.
        
        :return: Estimated build time in arbitrary units.
        """
        total_time = 0
        task_order = self.get_task_order()  # Get the order of tasks based on dependencies

        for task_id in task_order:
            code_snippet = self.task_code_map.get(task_id)
            if code_snippet is None:
                raise ValueError(f"No code snippet associated with task ID {task_id}.")
            task_efficiency = self.code_efficiency.get(code_snippet, 1)  # Default to 1 if no efficiency data
            base_time_per_task = 10 / task_efficiency  # Adjust base time based on efficiency
            dependencies = self.tasks.get(task_id, {}).get('dependencies', [])  # Get dependencies for the current task
            dependency_time = 5 * len(dependencies)  # Calculate total dependency time
            total_time += base_time_per_task + dependency_time  # Add task time and dependency time to total

        return total_time

    def get_task_order(self):
        """
        Determine the order in which tasks should be executed based on their dependencies using a topological sort.

        :return: List of task IDs in the order they should be executed.
        """
        from collections import deque

        # Calculate in-degrees for each task
        in_degree = {task_id: 0 for task_id in self.tasks}
        for task_id, task_details in self.tasks.items():
            for dependency in task_details['dependencies']:
                in_degree[dependency] += 1

        # Initialize queue with tasks that have no dependencies
        queue = deque([task_id for task_id, degree in in_degree.items() if degree == 0])
        task_order = []

        while queue:
            task_id = queue.popleft()
            task_order.append(task_id)
            for dependent_task, task_details in self.tasks.items():
                if task_id in task_details['dependencies']:
                    in_degree[dependent_task] -= 1
                    if in_degree[dependent_task] == 0:
                        queue.append(dependent_task)

        return task_order

    def mark_task_completed(self, task_id):
        """
        Mark a task as completed.

        :param task_id: Unique identifier for the task.
        """
        if task_id not in self.tasks:
            raise ValueError(f"Task ID {task_id} does not exist.")
        self.tasks[task_id]['completed'] = True

    def get_task_status(self, task_id):
        """
        Get the status of a task.

        :param task_id: Unique identifier for the task.
        :return: Status of the task (completed or not).
        """
        if task_id not in self.tasks:
            raise ValueError(f"Task ID {task_id} does not exist.")
        return self.tasks[task_id]['completed']

# Example usage
