    # Adding tasks with dependencies
    ots.add_task('task1', 'Implement feature A', datetime.date(2023, 10, 1), 1)
    ots.add_task('task2', 'Implement feature B', datetime.date(2023, 10, 2), 2, ['task1'])
    ots.add_task('task3', 'Implement feature C', datetime.date(2023, 10, 3), 3, ['task1'])
    ots.add_task('task4', 'Implement feature D', datetime.date(2023, 10, 4), 4, ['task2', 'task3'])

    # Analyzing code snippets
    code1 = "def function1():\n    return 1"
    code2 = "def function2():\n    return 2"
    print(f"Efficiency of code1: {ots.analyze_code('task1', code1)}")
    print(f"Efficiency of code2: {ots.analyze_code('task2', code2)}")

    # Estimating build time
    print(f"Estimated build time: {ots.estimate_build_time()} units")

    # Getting task order
    print(f"Task order: {ots.get_task_order()}")
