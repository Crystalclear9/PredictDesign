        if task_id in self.tasks:
            self.tasks[task_id].update_time_slot(new_time_slot)

    def update_task_priority(self, task_id, new_priority):
        """Update the priority of a task."""
        if task_id in self.tasks:
            self.tasks[task_id].update_priority(new_priority)

