        :return: list - A list of task IDs in the order they should be executed.
        """
        in_degree = {u: 0 for u in self.tasks}
        for u in self.tasks:
            for v in self.tasks[u]:
                in_degree[v] += 1
        queue = [u for u in in_degree if in_degree[u] == 0]
        result = []
        while queue:
            u = queue.pop(0)
            result.append(u)
            for v in self.tasks[u]:
                in_degree[v] -= 1
                if in_degree[v] == 0:
                    queue.append(v)
        if len(result) == len(self.tasks):
            return result
        else:
            raise ValueError('Cycle detected in the task dependencies')

